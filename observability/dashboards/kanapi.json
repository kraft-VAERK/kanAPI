{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Endpoint Avg Response Time (ms)",
      "type": "barchart",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "showValue": "auto",
        "stacking": "none",
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "avg_over_time({job=\"kanapi\"} | json | event = \"http_request\" | unwrap duration_ms [5m]) by (path)",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Request Rate by Endpoint",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "count_over_time({job=\"kanapi\"} | json | event = \"http_request\" [1m]) by (path)",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "User Activity",
      "type": "table",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 10 },
      "datasource": { "type": "loki", "uid": "" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Request Count" }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Request Count", "desc": true }]
      },
      "transformations": [
        {
          "id": "sortBy",
          "options": { "sort": [{ "field": "Value", "order": "desc" }] }
        }
      ],
      "targets": [
        {
          "expr": "count_over_time({job=\"kanapi\"} | json | event = \"http_request\" | username != \"anonymous\" [$__range]) by (username, email)",
          "legendFormat": "{{username}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "title": "Recent Requests",
      "type": "logs",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 10 },
      "datasource": { "type": "loki", "uid": "" },
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": false,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "expr": "{job=\"kanapi\"} | json | event = \"http_request\"",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Error Rate (4xx + 5xx)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 20 },
      "datasource": { "type": "loki", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "count_over_time({job=\"kanapi\"} | json | event = \"http_request\" | status_code >= 400 [5m])",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Avg Response Time (all endpoints)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 20 },
      "datasource": { "type": "loki", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 1000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["mean"] },
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "avg_over_time({job=\"kanapi\"} | json | event = \"http_request\" | unwrap duration_ms [5m])",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["kanapi", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "kanAPI Observability",
  "uid": "kanapi-main",
  "version": 1,
  "refresh": "10s"
}
